namespace ArraysPractica
{
    internal class Program
    {
        static void Main(string[] args)
        {
           
            int[] array = new int[10];
            int may = int.MinValue;
            int men = int.MaxValue;


            for (int i = 0; i < 10; i++)
            {
                Console.WriteLine($"Ingrese el numero {i + 1}");
                array[i] = Convert.ToInt16(Console.ReadLine());
                if (array[i] > may)
                {
                    may = array[i];
                }
               
               
                if (array[i] < men)
                 {
                     men = array[i];
                 }
               
            }


            Console.WriteLine($"El numero mas grande encontrado dentro del array es {may}");
            Console.WriteLine($"Y el numero mas pequeno encontrado dentro del array es {men}");


           
        }
    }
}






