namespace ArraysPractica
{
    internal class Program
    {
        static void Main(string[] args)
        {
           
            int[] array = new int[10];
            int diff = 0;
            int total = 0;
            int promedio = 0;


            for (int i = 0; i < 10; i++)
            {
                Console.WriteLine($"Ingrese el numero {i + 1}");
                array[i] = Convert.ToInt16(Console.ReadLine());
                total = array[i] + total;
               
               
            }


            promedio = total / 10;


            Console.WriteLine($"El promedio de todos los numero es de {promedio}");
            Console.WriteLine($"============================================");


            for (int i = 0; i < 10; i++)
            {
                diff = promedio - array[i];
                Console.WriteLine($"La diferencia entre {i} y {promedio} es de {diff}");
               
            }            
           


           
        }
    }
}





